---
import TransparentLayout from '../layouts/TransparentLayout.astro';
---

<TransparentLayout>
  <div id="notification-container"></div>

  <script>
    import { listen } from '@tauri-apps/api/event';
    import { invoke } from '@tauri-apps/api/core';

    interface NotificationPayload {
      id: string;
      title: string;
      message: string;
      type: string;
      priority: number;
    }

    let destroyTimer: number | null = null;

    function getTypeColor(type: string): string {
      const colors: Record<string, string> = {
        HabitReminder: '#60a5fa',
        ContextSwitchWarning: '#f59e0b',
        SmartBreakReminder: '#34d399',
        ProjectProgressReminder: '#a78bfa',
        MorningReminder: '#fbbf24',
        WaterReminder: '#38bdf8',
        SedentaryReminder: '#fb923c',
        ScreenInactivityReminder: '#94a3b8',
        ReturnReminder: '#4ade80',
        Custom: '#e2e8f0',
      };
      return colors[type] || '#e2e8f0';
    }

    function getTypeIcon(type: string): string {
      const icons: Record<string, string> = {
        HabitReminder: '🔁',
        ContextSwitchWarning: '⚡',
        SmartBreakReminder: '☕',
        ProjectProgressReminder: '📋',
        MorningReminder: '🌅',
        WaterReminder: '💧',
        SedentaryReminder: '🧘',
        ScreenInactivityReminder: '🖥️',
        ReturnReminder: '👋',
        Custom: '🔔',
      };
      return icons[type] || '🔔';
    }

    function destroyWindow() {
      if (destroyTimer) {
        clearTimeout(destroyTimer);
        destroyTimer = null;
      }
      invoke('destroy_notification_window').catch(console.error);
    }

    function showNotification(payload: NotificationPayload) {
      const container = document.getElementById('notification-container');
      if (!container) return;

      const color = getTypeColor(payload.type);
      const icon = getTypeIcon(payload.type);

      container.innerHTML = `
        <div class="notification-card">
          <div class="card-accent" style="background: ${color}"></div>
          <div class="card-body">
            <div class="card-header">
              <span class="card-icon">${icon}</span>
              <span class="card-title">${payload.title}</span>
            </div>
            <div class="card-message">${payload.message}</div>
            <button class="ok-button">好的</button>
          </div>
        </div>
      `;

      // 10秒后自动销毁
      destroyTimer = window.setTimeout(destroyWindow, 10000);

      // 点击"好的"按钮销毁
      container.querySelector('.ok-button')?.addEventListener('click', destroyWindow);
    }

    window.addEventListener('DOMContentLoaded', () => {
      listen<NotificationPayload>('notification:new', (event) => {
        showNotification(event.payload);
      });
    });
  </script>

  <style is:global>
    body {
      margin: 0;
      padding: 0;
      background: transparent;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }

    #notification-container {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 8px;
      width: 360px;
      box-sizing: border-box;
    }

    .notification-card {
      display: flex;
      flex-direction: row;
      background: rgba(30, 30, 40, 0.95);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.08);
      cursor: pointer;
      user-select: none;
      will-change: opacity, transform;
    }

    .notification-card:hover {
      border-color: rgba(255, 255, 255, 0.15);
    }

    .card-accent {
      width: 4px;
      flex-shrink: 0;
    }

    .card-body {
      flex: 1;
      padding: 12px 14px;
      min-width: 0;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 6px;
    }

    .card-icon {
      font-size: 14px;
      flex-shrink: 0;
    }

    .card-title {
      font-size: 13px;
      font-weight: 600;
      color: #fff;
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .card-close {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.4);
      font-size: 16px;
      cursor: pointer;
      padding: 0 2px;
      line-height: 1;
      flex-shrink: 0;
      transition: color 150ms ease;
    }

    .card-close:hover {
      color: rgba(255, 255, 255, 0.8);
    }

    .card-message {
      font-size: 12px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.7);
      word-break: break-word;
      margin-bottom: 12px;
    }

    .ok-button {
      width: 100%;
      padding: 8px;
      background: rgba(96, 165, 250, 0.2);
      border: 1px solid rgba(96, 165, 250, 0.3);
      border-radius: 6px;
      color: #60a5fa;
      font-size: 13px;
      cursor: pointer;
      transition: all 150ms ease;
    }

    .ok-button:hover {
      background: rgba(96, 165, 250, 0.3);
      border-color: rgba(96, 165, 250, 0.5);
    }
  </style>
</TransparentLayout>
