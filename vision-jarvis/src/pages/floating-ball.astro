---
import TransparentLayout from '../layouts/TransparentLayout.astro';
import Ball from '../components/FloatingBall/Ball.astro';
import Header from '../components/FloatingBall/Header.astro';
import Asker from '../components/FloatingBall/Asker.astro';
---

<TransparentLayout>
  <!-- 垂直布局: Ball 在上，Expansion 在下 -->

  <!-- Ball Zone - 始终可见，Ball 靠右对齐 -->
  <div id="ball-zone" style="width: 100%; height: 64px; display: flex; align-items: center; justify-content: flex-end;">
    <Ball />
  </div>

  <!-- Expansion Zone - 动态显示，在 Ball 下方 -->
  <div id="expansion-zone" class="hidden" style="margin-top: 10px;">
    <!-- Header Expansion -->
    <div id="header-expansion" class="hidden">
      <Header />
    </div>

    <!-- Asker Expansion -->
    <div id="asker-expansion" class="hidden">
      <Asker />
    </div>
  </div>

  <script>
    import { invoke } from '@tauri-apps/api/core';
    import { getCurrentWindow, LogicalPosition } from '@tauri-apps/api/window';
    import { $settings, loadSettings, toggleMemory, initSettingsSync } from '../stores/settingsStore';
    import { TauriAPI } from '../lib/tauri-api';
    import { showNotification } from '../lib/utils';

    type WindowState = 'ball' | 'header' | 'asker';
    let currentState: WindowState = 'ball';
    let isTransitioning = false;
    let isSendingMessage = false;
    const BALL_POSITION_KEY = 'floating-ball-position';
    const TRANSITION_MS = 160;
    const MOVE_SAVE_DEBOUNCE_MS = 120;

    function getExpansionZone(): HTMLElement | null {
      return document.getElementById('expansion-zone');
    }

    function getHeaderExpansion(): HTMLElement | null {
      return document.getElementById('header-expansion');
    }

    function getAskerExpansion(): HTMLElement | null {
      return document.getElementById('asker-expansion');
    }

    function getBallZone(): HTMLElement | null {
      return document.getElementById('ball-zone');
    }

    function getAskerMessages(): HTMLElement | null {
      return document.getElementById('asker-messages');
    }

    function getAskerInput(): HTMLInputElement | null {
      return document.getElementById('asker-input') as HTMLInputElement | null;
    }

    function saveBallPosition(x: number, y: number) {
      localStorage.setItem(BALL_POSITION_KEY, JSON.stringify({ x, y }));
    }

    function readBallPosition(): { x: number; y: number } | null {
      const raw = localStorage.getItem(BALL_POSITION_KEY);
      if (!raw) return null;
      try {
        const parsed = JSON.parse(raw);
        if (typeof parsed?.x === 'number' && typeof parsed?.y === 'number') {
          return parsed;
        }
      } catch {}
      return null;
    }

    async function applySavedBallPosition() {
      const position = readBallPosition();
      if (!position) return;
      try {
        await getCurrentWindow().setPosition(new LogicalPosition(position.x, position.y));
      } catch (error) {
        console.error('Failed to restore floating-ball position:', error);
      }
    }

    async function saveCurrentBallPosition() {
      try {
        const appWindow = getCurrentWindow();
        const pos = await appWindow.outerPosition();
        const scale = await appWindow.scaleFactor();
        saveBallPosition(pos.x / scale, pos.y / scale);
      } catch (error) {
        console.error('Failed to save floating-ball position:', error);
      }
    }

    function appendAskerMessage(role: 'user' | 'assistant', text: string) {
      const messages = getAskerMessages();
      if (!messages) return;

      const emptyState = messages.querySelector('.text-center.text-muted');
      emptyState?.remove();

      const wrapper = document.createElement('div');
      wrapper.className = role === 'user' ? 'mb-3 flex justify-end' : 'mb-3 flex justify-start';

      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[85%] rounded-[20px] bg-white px-4 py-3 text-sm text-black'
        : 'max-w-[85%] rounded-[20px] bg-secondary px-4 py-3 text-sm text-primary';
      bubble.style.whiteSpace = 'pre-wrap';
      bubble.textContent = text;

      wrapper.appendChild(bubble);
      messages.appendChild(wrapper);
      messages.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
    }

    function setAskerSendingState(isSending: boolean) {
      isSendingMessage = isSending;
      const input = getAskerInput();
      const sendBtn = document.getElementById('asker-send') as HTMLButtonElement | null;
      if (input) input.disabled = isSending;
      if (sendBtn) {
        sendBtn.disabled = isSending;
        sendBtn.style.opacity = isSending ? '0.6' : '1';
      }
    }

    function formatSearchReply(query: string, chunks: Array<{ file_path: string; text: string }>): string {
      if (chunks.length === 0) {
        return `还没找到和“${query}”直接相关的记忆。\n\n如果这是刚发生的事情，等当前录屏分析和索引完成后再试一次。`;
      }

      return chunks
        .slice(0, 3)
        .map((chunk, index) => {
          const text = chunk.text.replace(/\s+/g, ' ').trim().slice(0, 180);
          return `${index + 1}. ${text}${text.length >= 180 ? '...' : ''}`;
        })
        .join('\n\n');
    }

    async function sendAskerMessage() {
      if (isSendingMessage) return;

      const input = getAskerInput();
      const message = input?.value.trim();
      if (!input || !message) return;

      appendAskerMessage('user', message);
      input.value = '';
      setAskerSendingState(true);

      try {
        const chunks = await TauriAPI.searchMemories(message, 5);
        appendAskerMessage('assistant', formatSearchReply(message, chunks));
      } catch (error) {
        console.error('Failed to search memories:', error);
        showNotification('发送失败: 无法查询记忆', 'error');
        appendAskerMessage('assistant', '这次查询失败了。请稍后再试。');
      } finally {
        setAskerSendingState(false);
        input.focus();
      }
    }

    function getResizeCommand(state: WindowState): string {
      const commands = {
        ball: 'collapse_to_ball',
        header: 'expand_to_header',
        asker: 'expand_to_asker',
      };
      return commands[state];
    }

    function delay(ms: number): Promise<void> {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function switchTo(state: WindowState) {
      if (currentState === state || isTransitioning) return;

      isTransitioning = true;
      const previousState = currentState;

      try {
        const expansionZone = getExpansionZone();
        const headerExp = getHeaderExpansion();
        const askerExp = getAskerExpansion();

        if (previousState !== 'ball') {
          const currentExp = previousState === 'header' ? headerExp : askerExp;
          currentExp?.classList.add('transitioning-out');
          await delay(TRANSITION_MS);
        }

        await invoke(getResizeCommand(state));

        if (state === 'ball') {
          expansionZone?.classList.add('hidden');
          headerExp?.classList.add('hidden');
          askerExp?.classList.add('hidden');
        } else {
          expansionZone?.classList.remove('hidden');

          if (state === 'header') {
            headerExp?.classList.remove('hidden');
            headerExp?.classList.add('transitioning-in');
            askerExp?.classList.add('hidden');
          } else {
            askerExp?.classList.remove('hidden');
            askerExp?.classList.add('transitioning-in');
            headerExp?.classList.add('hidden');
          }

          await delay(TRANSITION_MS);
          headerExp?.classList.remove('transitioning-in', 'transitioning-out');
          askerExp?.classList.remove('transitioning-in', 'transitioning-out');
        }

        currentState = state;

        if (state === 'ball') {
          await saveCurrentBallPosition();
        }
      } catch (error) {
        console.error('Transition failed:', error);
        currentState = previousState;
      } finally {
        isTransitioning = false;
      }
    }

    window.addEventListener('DOMContentLoaded', () => {
      const appWindow = getCurrentWindow();
      let moveSaveTimer: number | null = null;

      initSettingsSync();
      void applySavedBallPosition();
      void appWindow.onMoved(async ({ payload }) => {
        try {
          if (moveSaveTimer) window.clearTimeout(moveSaveTimer);
          const scale = await appWindow.scaleFactor();
          moveSaveTimer = window.setTimeout(() => {
            saveBallPosition(payload.x / scale, payload.y / scale);
          }, MOVE_SAVE_DEBOUNCE_MS);
        } catch (error) {
          console.error('Failed to persist floating-ball position:', error);
        }
      });

      const expansionZone = getExpansionZone();
      const headerExp = getHeaderExpansion();
      const askerExp = getAskerExpansion();
      expansionZone?.classList.add('hidden');
      headerExp?.classList.add('hidden');
      askerExp?.classList.add('hidden');

      document.getElementById('floating-ball-action')?.addEventListener('click', async (e) => {
        e.stopPropagation();
        console.log('Ball action clicked, current state:', currentState);

        if (currentState === 'ball') {
          await switchTo('header');
        } else if (currentState === 'header') {
          await switchTo('asker');
        } else {
          await switchTo('ball');
        }
      });

      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const expZone = getExpansionZone();
        const bZone = getBallZone();

        if (!expZone?.contains(target) && !bZone?.contains(target) && currentState !== 'ball') {
          switchTo('ball');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && currentState !== 'ball') {
          switchTo('ball');
        }
      });

      document.getElementById('memory-btn')?.addEventListener('click', async () => {
        try {
          await invoke('open_memory_window');
        } catch (error) {
          console.error('Failed to open memory window:', error);
        }
      });

      document.getElementById('popup-btn')?.addEventListener('click', async () => {
        try {
          await invoke('open_popup_setting_window');
        } catch (error) {
          console.error('Failed to open popup-setting window:', error);
        }
      });

      document.getElementById('close-asker')?.addEventListener('click', () => {
        switchTo('ball');
      });

      document.getElementById('asker-send')?.addEventListener('click', async (e) => {
        e.stopPropagation();
        await sendAskerMessage();
      });

      getAskerInput()?.addEventListener('keydown', async (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          e.stopPropagation();
          await sendAskerMessage();
        }
      });

      const memoryToggle = document.querySelector('.memory-toggle') as HTMLElement | null;
      let isMemoryEnabled = true;

      function updateHeaderToggleUI(enabled: boolean) {
        isMemoryEnabled = enabled;
        if (!memoryToggle) return;
        const ball = memoryToggle.querySelector('div') as HTMLElement;

        if (enabled) {
          memoryToggle.classList.remove('toggle-track-off');
          memoryToggle.classList.add('toggle-track-on', 'justify-end');
          if (ball) {
            ball.classList.remove('bg-[#555]');
            ball.classList.add('bg-black');
            ball.style.boxShadow = '0 1px 4px rgba(0,0,0,0.8)';
          }
        } else {
          memoryToggle.classList.remove('toggle-track-on', 'justify-end');
          memoryToggle.classList.add('toggle-track-off');
          if (ball) {
            ball.classList.remove('bg-black');
            ball.classList.add('bg-[#555]');
            ball.style.boxShadow = 'none';
          }
        }
      }

      memoryToggle?.addEventListener('click', async () => {
        const oldState = isMemoryEnabled;
        const newState = !oldState;
        try {
          updateHeaderToggleUI(newState);
          await toggleMemory(newState);
        } catch (error) {
          updateHeaderToggleUI(oldState);
          console.error('Failed to toggle memory:', error);
        }
      });

      loadSettings().then(() => {
        const settings = $settings.get();
        if (settings) {
          updateHeaderToggleUI(settings.memory_enabled);
        }
      });

      $settings.subscribe((settings) => {
        if (settings) {
          updateHeaderToggleUI(settings.memory_enabled);
        }
      });
    });
  </script>

  <style is:global>
    /* ========================================
     * 垂直布局样式 - Ball 在上，Expansion 在下
     * ======================================== */

    /* 确保 body 不会溢出 */
    body {
      width: 100%;
      max-width: 100vw;
      box-sizing: border-box;
    }

    /* Ball Zone - 宽度自适应窗口，Ball 靠右对齐 */
    #ball-zone {
      width: 100%;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: flex-end; /* Ball 始终靠右，避免瞬移 */
      /* 移除所有边框和背景 */
      border: none;
      outline: none;
      background: transparent;
    }

    /* Expansion Zone - 在 Ball 下方 */
    #expansion-zone {
      margin-top: 10px; /* 10px gap between ball and expansion */
      width: 100%;
    }

    /* Header Expansion */
    #header-expansion {
      width: 360px;
      height: 72px;
    }

    /* Asker Expansion */
    #asker-expansion {
      width: 360px;
      height: 480px;
    }

    /* 隐藏状态 */
    .hidden {
      display: none !important;
    }

    /* 过渡动画 */
    .transitioning-out {
      opacity: 0;
      transform: scale(0.95);
      transition: opacity 150ms ease-out, transform 150ms ease-out;
    }

    .transitioning-in {
      opacity: 0;
      transform: scale(1.05);
      animation: fadeIn 150ms ease-out forwards;
    }

    @keyframes fadeIn {
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    /* ========================================
     * 自定义滚动条
     * ======================================== */
    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.2);
      border-radius: 2px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.3);
    }
  </style>
</TransparentLayout>
