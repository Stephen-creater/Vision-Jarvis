---
// 360x72 Header 展开状态
---

<div
  id="header-expanded"
  class="bg-card rounded-[30px] border border-primary flex items-center gap-3 px-4 transition-all duration-300 shadow-[0_12px_36px_rgba(0,0,0,0.24)]"
  style="width: 360px; height: 72px;"
  data-tauri-drag-region
>
  <!-- Memory Toggle -->
  <div class="memory-toggle h-9 w-[84px] toggle-track-on rounded-full flex items-center justify-end px-1 cursor-pointer border border-white/10 transition-all duration-200" style="-webkit-app-region: no-drag;">
    <div class="h-7 w-7 rounded-full bg-black pointer-events-none shadow-[0_2px_8px_rgba(0,0,0,0.55)]"></div>
  </div>

  <!-- Memory Button -->
  <button
    id="memory-btn"
    class="h-9 min-w-[92px] bg-secondary rounded-full border border-primary px-3 flex items-center justify-center gap-2 hover:border-active hover:bg-white/6 transition-colors"
    style="-webkit-app-region: no-drag;"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-secondary">
      <ellipse cx="12" cy="5" rx="9" ry="3"/>
      <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
    </svg>
    <span class="text-secondary text-[15px] font-medium leading-none">记忆</span>
  </button>

  <!-- Popup Button -->
  <button
    id="popup-btn"
    class="h-9 min-w-[100px] bg-secondary rounded-full border border-primary px-3 flex items-center justify-center gap-2 hover:border-active hover:bg-white/6 transition-colors"
    style="-webkit-app-region: no-drag;"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-secondary">
      <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    <span class="text-secondary text-[15px] font-medium leading-none">设置</span>
  </button>
</div>
